{
  "schema_version": "v1",
  "name": "Logwick",
  "description": "The audit log for AI agents. Query logs, get stats, and ingest log entries via natural language.",
  "version": "1.0.1",
  "serverUrl": "https://logwick.io/api/mcp",
  "url": "https://logwick.io",
  "install": {
    "type": "npx",
    "command": "npx",
    "args": ["-y", "@logwick/mcp"],
    "env": {
      "LOGWICK_API_KEY": {
        "description": "Your Logwick API key from logwick.io/dashboard",
        "required": true
      }
    }
  },
  "tools": [
    {
      "name": "ingest_log",
      "description": "Log an AI agent action to Logwick.",
      "inputSchema": {
        "type": "object",
        "required": ["agent", "action"],
        "properties": {
          "agent": { "type": "string" },
          "action": { "type": "string" },
          "status": { "type": "string", "enum": ["success", "error", "pending"] },
          "input": { "type": "string" },
          "output": { "type": "string" },
          "tokens": { "type": "number" },
          "latency_ms": { "type": "number" },
          "user": { "type": "string" }
        }
      }
    },
    {
      "name": "query_logs",
      "description": "Search and retrieve logs.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "agent": { "type": "string" },
          "action": { "type": "string" },
          "search": { "type": "string" },
          "limit": { "type": "number" }
        }
      }
    },
    {
      "name": "get_stats",
      "description": "Get usage stats — success rate, tokens, cost.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "days": { "type": "number" }
        }
      }
    },
    {
      "name": "get_log",
      "description": "Get full details of a single log entry by ID.",
      "inputSchema": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string" }
        }
      }
    },
    {
      "name": "delete_log",
      "description": "Delete a log entry by ID.",
      "inputSchema": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string" }
        }
      }
    }
  ],
  "auth": {
    "type": "bearer",
    "description": "API key from logwick.io/dashboard"
  }
}
